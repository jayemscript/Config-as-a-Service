# Config-as-a-Service Environment Configuration

# API Server
PORT=12500
HOST=127.0.0.1

# Database
DATABASE_URL=sqlite:///./caas_data.db

# Encryption
# Generate a new key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# JWT Authentication
# Generate a new secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
